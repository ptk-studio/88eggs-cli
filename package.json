{
  "name": "rainbow-cli",
  "version": "0.1.0",
  "description": "CLI for Rainbow -- sign in and drive rainbow-backend from the command line.",
  "type": "module",
  "bin": {
    "rainbow": "./dist/index.js"
  },
  "files": [
